# Google Gemini API Key
GOOGLE_API_KEY="your-api-key-here"

# EthanComputer 配置
ETHAN_USER_ID="ethan"
ETHAN_DATA_DIR="./data"

# Model 配置
# Gemini（默认）: ETHAN_MODEL_NAME="gemini-2.5-flash"
# GLM（智谱AI）:   ETHAN_MODEL_NAME="openai/glm-4-flash" + ETHAN_MODEL_API_BASE + OPENAI_API_KEY
# OpenAI:         ETHAN_MODEL_NAME="openai/gpt-4o" + OPENAI_API_KEY
# Anthropic:      ETHAN_MODEL_NAME="anthropic/claude-sonnet-4-20250514" + ANTHROPIC_API_KEY
ETHAN_MODEL_NAME="gemini-2.5-flash"
ETHAN_MODEL_API_BASE=""
